# Local development defaults. Copy to .env and replace every credential before
# exposing the service to a network.
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql+psycopg2://welding:replace-me@postgres:5432/welding

JWT_SECRET=replace-with-at-least-32-random-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=replace-with-a-strong-password
SUPERADMIN_EMAIL=admin@example.com

# Use explicit trusted origins in production, for example:
# CORS_ORIGINS=["https://dashboard.example.com"]
CORS_ORIGINS=["*"]

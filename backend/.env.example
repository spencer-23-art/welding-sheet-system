# 后端环境变量示例（复制为 .env 后修改）

# 数据库：本地开发用 SQLite；Docker 内改为 PostgreSQL 连接串
DATABASE_URL=sqlite:///./app.db
# DATABASE_URL=postgresql+psycopg2://welding:welding123@postgres:5432/welding

# JWT（生产务必改为随机长字符串，建议 >=32 字节）
JWT_SECRET=dev-secret-change-me-please-change-in-prod-32b+
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis（第二阶段协作 / 令牌黑名单）
REDIS_URL=redis://redis:6379/0

# 超级管理员初始账号
SUPERADMIN_USERNAME=admin
SUPERADMIN_PASSWORD=Admin@123456
SUPERADMIN_EMAIL=admin@example.com

# CORS（生产改为前端域名）
CORS_ORIGINS=["*"]
